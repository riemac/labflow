{
  "mcpServers": {
    "pdf-reader": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@sylphx/pdf-reader-mcp"
      ]
    },
    "augmentcode": {
      "type": "stdio",
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@upstash/context7-mcp@1.0.30"
      ]
    }
  }
}
