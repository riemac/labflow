#!/usr/bin/env bash
set -euo pipefail

# 这个脚本启动一个独立的 LabPrompt 主会话，用来讨论和锻造可交给 Codex 的任务 prompt。
# 默认工作目录是当前目录；如需指定项目目录，可设置 LABFLOW_PROJECT_DIR=/abs/project。
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
prompt_file="${script_dir}/../prompts/labprompt.md"
project_dir="${LABFLOW_PROJECT_DIR:-$PWD}"
user_prompt="${*:-}"

# 命令行追加内容会作为本次锻造的粗糙需求，方便快速进入讨论。
if [[ -n "${user_prompt}" ]]; then
  exec codex -C "${project_dir}" "$(printf '%s\n\n用户粗糙需求：\n%s\n' "$(<"${prompt_file}")" "${user_prompt}")"
else
  exec codex -C "${project_dir}" "$(<"${prompt_file}")"
fi
