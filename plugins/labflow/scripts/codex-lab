#!/usr/bin/env bash
set -euo pipefail

# 这个脚本把 Lab prompt 作为 Codex 的首条用户输入，方便从任意科研项目中启动主会话。
# 默认工作目录是当前目录；如需指定项目目录，可设置 LABFLOW_PROJECT_DIR=/abs/project。
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
prompt_file="${script_dir}/../prompts/lab.md"
project_dir="${LABFLOW_PROJECT_DIR:-$PWD}"
user_prompt="${*:-}"

# 如果用户在命令后追加了一句话，把它拼到 Lab 启动说明后面，避免再手动粘贴一次。
if [[ -n "${user_prompt}" ]]; then
  exec codex -C "${project_dir}" "$(printf '%s\n\n用户初始输入：\n%s\n' "$(<"${prompt_file}")" "${user_prompt}")"
else
  exec codex -C "${project_dir}" "$(<"${prompt_file}")"
fi
